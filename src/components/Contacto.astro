---
const links = [
  {
    label: "GitHub",
    value: "github.com/ivanajenjo",
    href: "https://github.com/ivanajenjo",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
  {
    label: "LinkedIn",
    value: "Iván Iñaki Ajenjo",
    href: "https://www.linkedin.com/in/iv%C3%A1n-i%C3%B1aki-ajenjo-vicente-2136031b7/",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
];
---

<section id="contact" class="py-24 px-6 bg-white/[0.02]">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="mb-16 text-center">
      <p class="text-cyan-400 font-mono text-sm tracking-widest uppercase mb-2">
        Contact
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-white">Let's connect</h2>
      <p class="text-white/50 mt-4 max-w-md mx-auto">
        Open to new opportunities, technical discussions, and interesting
        collaborations.
      </p>
    </div>

    <div class="max-w-2xl mx-auto">
      <!-- Contact cards -->
      <div class="grid sm:grid-cols-2 gap-4 mb-10">
        {
          links.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith("mailto") ? undefined : "_blank"}
              rel="noopener noreferrer"
              class="group flex flex-col items-center gap-3 p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-white/30 hover:bg-white/10 transition-all duration-300 text-center"
            >
              <span
                class="text-white/50 group-hover:text-white transition-colors"
                set:html={link.icon}
              />
              <div>
                <p class="text-white font-medium text-sm">{link.label}</p>
                <p class="text-white/40 text-xs mt-0.5 font-mono break-all">
                  {link.value}
                </p>
              </div>
            </a>
          ))
        }
      </div>

      <!-- CTA -->
      <div class="relative rounded-2xl overflow-hidden">
        <div
          class="absolute inset-0 bg-gradient-to-br from-purple-500/20 via-blue-500/20 to-cyan-500/20"
        >
        </div>
        <div class="absolute inset-0 border border-white/10 rounded-2xl"></div>
        <div class="relative p-10 text-center">
          <h3 class="text-2xl font-bold text-white mb-3">
            Got an interesting challenge?
          </h3>
          <p class="text-white/50 mb-6 max-w-sm mx-auto text-sm">
            Whether it's a backend architecture problem, a cloud migration, or
            just a conversation about distributed systems — I'm in.
          </p>
          <a
            href="https://www.linkedin.com/in/iv%C3%A1n-i%C3%B1aki-ajenjo-vicente-2136031b7/"
            target="_blank"
            class="inline-block px-8 py-3 rounded-full bg-gradient-to-r from-purple-500 via-blue-500 to-cyan-500 text-white font-semibold text-sm hover:opacity-90 transition-opacity shadow-lg shadow-purple-500/25"
          >
            Send a message
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
