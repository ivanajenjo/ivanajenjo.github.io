---
const skills = [
  'Java', 'Spring Boot', 'Apache Kafka',
  'Google Cloud (GCP)', 'Kubernetes', 'Docker',
  'RESTful APIs', 'Microservices', 'CI/CD', 'PostgreSQL',
];
---

<section id="about" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="mb-16 text-center">
      <p class="text-cyan-400 font-mono text-sm tracking-widest uppercase mb-2">About me</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white">Who I am</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Avatar -->
      <div class="flex justify-center">
        <div class="relative">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-purple-500 via-blue-500 to-cyan-500 blur-xl opacity-30 scale-105"></div>
          <div class="relative w-64 h-64 md:w-80 md:h-80 rounded-2xl bg-gradient-to-br from-purple-900/60 to-blue-900/60 border border-white/10 flex items-center justify-center">
            <span class="text-8xl select-none">👨‍💻</span>
          </div>
        </div>
      </div>

      <!-- Text content -->
      <div class="space-y-5">
        <p class="text-white/70 text-lg leading-relaxed">
          I engineer high-performance backend systems designed to scale.
          With <span class="text-white font-medium">4+ years at Mercadona</span>, I've architected
          distributed microservices, driven event-streaming solutions with Kafka,
          and orchestrated cloud-native infrastructure on GCP.
        </p>
        <p class="text-white/60 leading-relaxed">
          I thrive at the intersection of software quality and system design —
          whether it's optimizing service performance, streamlining CI/CD pipelines,
          or designing resilient APIs that power large-scale operations.
        </p>
        <p class="text-white/60 leading-relaxed">
          Currently focused on expanding my expertise in cloud-native architectures
          and distributed systems, and contributing to teams that value
          technical excellence and continuous improvement.
        </p>

        <!-- Skills -->
        <div>
          <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">Tech stack</h3>
          <div class="flex flex-wrap gap-2">
            {skills.map(skill => (
              <span class="px-3 py-1 rounded-full text-sm font-mono bg-white/5 border border-white/10 text-white/70 hover:border-purple-400/50 hover:text-white transition-all cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <div class="flex items-center gap-6 pt-2">
          <a
            href="https://www.linkedin.com/in/iv%C3%A1n-i%C3%B1aki-ajenjo-vicente-2136031b7/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-cyan-400 hover:text-cyan-300 transition-colors font-mono"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a
            href="https://github.com/ivanajenjo"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-white/50 hover:text-white transition-colors font-mono"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
